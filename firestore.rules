rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: albums
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - date: string (required)
    //   - createdAt: number (required)
    //
    // Collection: photos
    // Fields:
    //   - albumId: string (required)
    //   - url: string (required)
    //   - name: string (required)
    //   - size: number (required)
    //   - type: string (required)
    //   - createdAt: number (required)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "niyonzimaemmanuel85@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidAlbum(data) {
      return data.keys().hasAll(['title', 'date', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.date is string &&
             data.createdAt is number;
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['albumId', 'url', 'name', 'createdAt']) &&
             data.albumId is string &&
             data.url is string && data.url.size() < 2000000 && // Base64 can be large
             data.name is string && data.name.size() < 255 &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /albums/{albumId} {
      allow read: if true; // Publicly visible as requested
      allow create, update: if isAdmin() && isValidAlbum(request.resource.data);
      allow delete: if isAdmin();
    }

    match /photos/{photoId} {
      allow read: if true; // Publicly visible as requested
      allow create: if isAdmin() && isValidPhoto(request.resource.data);
      allow update: if isAdmin() && isValidPhoto(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
