rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: albums
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - date: string (required)
    //   - createdAt: number (required)
    //
    // Collection: photos
    // Fields:
    //   - albumId: string (required)
    //   - url: string (required)
    //   - name: string (required)
    //   - size: number (required)
    //   - type: string (required)
    //   - createdAt: number (required)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "niyonzimaemmanuel85@gmail.com");
    }

    function isContributor() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contributor' || isAdmin());
    }

    function isValidAlbum(data) {
      return data.keys().hasAll(['title', 'date', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.date is string &&
             data.createdAt is number &&
             (!('titleColor' in data) || data.titleColor is string) &&
             (!('titleSize' in data) || data.titleSize is string) &&
             (!('titleFont' in data) || data.titleFont is string) &&
             (!('passcode' in data) || data.passcode is string) &&
             (!('isLocked' in data) || data.isLocked is bool);
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['albumId', 'url', 'imageUrl', 'name', 'fileName', 'storagePath', 'createdAt', 'uploadedAt', 'uploadedBy', 'uploaderEmail']) &&
             data.albumId is string &&
             data.url is string &&
             data.imageUrl is string &&
             data.name is string && data.name.size() < 255 &&
             data.fileName is string &&
             data.storagePath is string &&
             data.createdAt is number &&
             data.uploadedBy == request.auth.uid &&
             data.uploaderEmail == request.auth.token.email &&
             (!('tags' in data) || data.tags is list) &&
             (!('eventName' in data) || data.eventName is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /albums/{albumId} {
      allow read: if isAuthenticated(); 
      allow create, update: if isAdmin() && isValidAlbum(request.resource.data);
      allow delete: if isAdmin();
    }

    match /photos/{photoId} {
      allow read: if isAuthenticated(); 
      allow create: if isContributor() && isValidPhoto(request.resource.data);
      allow update: if isContributor() && isValidPhoto(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
