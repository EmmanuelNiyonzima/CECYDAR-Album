{
  "entities": {
    "Album": {
      "title": "Album",
      "description": "Represents a photo album or activity",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the album" },
        "description": { "type": "string", "description": "Description of the activity" },
        "date": { "type": "string", "format": "date", "description": "Date of the activity" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["title", "date", "createdAt"]
    },
    "Photo": {
      "title": "Photo",
      "description": "Represents a single photo in an album",
      "type": "object",
      "properties": {
        "albumId": { "type": "string", "description": "Reference to the parent album" },
        "url": { "type": "string", "format": "uri", "description": "Storage URL of the image" },
        "name": { "type": "string", "description": "Filename of the image" },
        "size": { "type": "number", "description": "Size in bytes" },
        "type": { "type": "string", "description": "MIME type" },
        "createdAt": { "type": "number", "description": "Timestamp of upload" }
      },
      "required": ["albumId", "url", "name", "createdAt"]
    }
  },
  "firestore": {
    "/albums/{albumId}": {
      "schema": "Album",
      "description": "Collection of photo albums"
    },
    "/photos/{photoId}": {
      "schema": "Photo",
      "description": "Collection of all photos across all albums"
    }
  }
}
